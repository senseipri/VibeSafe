# VibeSafe — Environment Variables
# Copy this file: cp .env.example .env  and fill in real values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vibesafe:vibesafe_dev@localhost:5432/vibesafe
TEST_DATABASE_URL=postgresql+asyncpg://vibesafe:vibesafe_dev@localhost:5432/vibesafe_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM API Keys ──────────────────────────────────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# ── GitHub (optional – increases rate limit for repo cloning) ─────────────────
GITHUB_TOKEN=

# ── Scan limits ───────────────────────────────────────────────────────────────
MAX_REPO_SIZE_MB=50
MAX_FILES_PER_SCAN=500
SCAN_TIMEOUT_SECONDS=120
